{
  "redis": {
    "host": "127.0.0.1",
    "port": 6379,
    "db": 0
  },
  "musician": {
    "queue_key": "orchestra:jobs",
    "dlq_key": "orchestra:dlq",
    "timeout_seconds": 300,
    "block_seconds": 5
  },
  "playbooks": {
    "deactivated": []
  },
  "secrets": {
    "backend": "env",
    "backend_configs": {
      "env": {
        "path": ".env"
      },
      "docker_secrets": {
        "path": "/run/secrets"
      },
      "aws_ssm": {
        "region": "ap-southeast-2",
        "prefix": "/orchestra/"
      }
    }
  },
  "llm": {
    "provider": "openai",
    "model": "gpt-5.5"
  },
  "dedupe": {
    "webhook_idempotency_ttl_seconds": 86400,
    "scheduler_ttl_seconds": 120
  }
}